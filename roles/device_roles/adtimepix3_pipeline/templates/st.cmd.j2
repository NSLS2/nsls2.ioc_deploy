#!/bin/bash

# Configure EPICS network environment variables
export EPICS_CA_AUTO_ADDR_LIST=NO
export EPICS_CAS_AUTO_BEACON_ADDR_LIST=NO
export EPICS_CA_ADDR_LIST="{{ host_config.epics_interface.broadcast }}"
export EPICS_CAS_BEACON_ADDR_LIST="{{ host_config.epics_interface.broadcast }}"

# Start IOC here.
{{ ioc.pixi_executable_path | default(deploy_ioc_pixi_executable_path) }} run python -m tpx3_pipeline.ioc --path "{{ ioc.environment.PATH }}" --prefix '{{ ioc.environment.PREFIX | replace('{', '{{') | replace('}', '}}') }}'
